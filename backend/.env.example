# Database
DATABASE_URL=sqlite+aiosqlite:///./data/invoices.db

# Storage
STORAGE_PATH=./data/invoices

# Auth
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_BCRYPT_HASH
JWT_SECRET=change-me-32-char-random-string-here
JWT_EXPIRE_MINUTES=1440

# Multi-user: enable self-service registration via POST /auth/register.
# New users are non-admin; an existing admin can promote them via /admin.
# Default is false — a single-operator deployment stays closed.
ALLOW_REGISTRATION=false

# Outlook scanner: route Microsoft Graph fetching through the v1.1.0 delta
# query (/me/mailFolders/{id}/messages/delta) instead of the legacy
# receivedDateTime ge polling. Default is true (delta on). Set to false
# to fall back to v0.9.x polling — kill-switch for production safety.
# When false, accounts whose state is already v1.1.0 format are SKIPPED
# (state preserved byte-identical) until the flag flips back on.
OUTLOOK_DELTA_ENABLED=true

# When a delta_link returns 410 Gone (resyncRequired), automatically
# fall back to a fresh initial sync. Disable for debugging unexpected
# 410-loop scenarios. Default is true.
OUTLOOK_DELTA_FALLBACK_ON_RESYNC=true

# v1.2.0 Track A kill-switch. When true, reverts to v1.1.x rejection
# behavior: any document whose invoice_type is not in VALID_INVOICE_TYPES
# AND is_valid_tax_invoice=false gets rejected with outcome=not_vat_invoice.
# When false (default), non-VAT categories (receipt / proforma / overseas_invoice /
# other) save normally — only invoice_category=vat_invoice rows with
# is_valid_tax_invoice=false get rejected.
STRICT_VAT_ONLY=false

# LLM (OpenAI-compatible)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
LLM_EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# Scheduler
SCAN_INTERVAL_MINUTES=60

# Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL). Default: INFO.
LOG_LEVEL=INFO

# Features
SQLITE_VEC_ENABLED=true

# Outlook OAuth defaults. Personal accounts use the Microsoft consumers tenant.
# Work/school accounts use the common Azure AD tenant.
# OUTLOOK_PERSONAL_CLIENT_ID=04b07795-8ddb-461a-bbee-02f9e1bf7b46
# OUTLOOK_AAD_CLIENT_ID=d3590ed6-52b3-4102-aeff-aad2292ab01c
