# Database
DATABASE_URL=sqlite+aiosqlite:///./data/invoices.db

# Storage
STORAGE_PATH=./data/invoices

# Auth
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_BCRYPT_HASH
JWT_SECRET=change-me-32-char-random-string-here
JWT_EXPIRE_MINUTES=1440

# LLM (OpenAI-compatible)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
LLM_EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# Scheduler
SCAN_INTERVAL_MINUTES=60

# Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL). Default: INFO.
LOG_LEVEL=INFO

# Features
SQLITE_VEC_ENABLED=true
